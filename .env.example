# ─────────────────────────────────────────────────────────────────────────────
# Portale clienti VeroLED — areaclienti.veroledsrl.com  (TEMPLATE)
# Solo NOMI delle variabili. I valori VERI vanno:
#   • PRODUZIONE -> Cloudflare Pages › Settings › Environment variables
#   • LOCALE     -> file ".dev.vars" (ignorato da git), per `wrangler pages dev`
#
# VEROLED_KV NON è una variabile: è un *binding* KV namespace, da collegare in
#   Cloudflare Pages › Settings › Functions › KV namespace bindings (nome: VEROLED_KV).
#   Serve a login clienti, provisioning e cache stato VNNOX.
# MEDIA NON è una variabile: è un *binding* R2 bucket (Settings › Functions › R2
#   bucket bindings, nome: MEDIA). Serve all'upload dei contenuti del Compositore;
#   i file sono serviti pubblicamente da /api/media/{key}.
# VEROCRM — il CRM (/crm) usa HubSpot come backend. Le Functions /api/crm/* fanno
#   da proxy verso l'API HubSpot CRM v3 e richiedono la variabile HUBSPOT_TOKEN
#   (vedi sotto). Senza token /api/crm/* risponde 503 e /crm mostra i dati demo.
# ─────────────────────────────────────────────────────────────────────────────

# ── NovaStar VNNOX OpenAPI (NovaCloud Open Platform) ──
VNNOX_APPKEY=
VNNOX_APPSECRET=
# Nodo regione. Default: https://open-eu.vnnox.com
VNNOX_BASE=
# 'mock' = dati finti (default se mancano le chiavi · abilita il login demo) · 'live' = API reale.
VNNOX_MODE=

# ── Sicurezza portale ──
# Firma le sessioni cliente (cookie vl_portale). Stringa lunga e casuale.
PORTALE_SECRET=
# Password del pannello /admin (provisioning clienti del portale).
ADMIN_SECRET=
# Token che protegge l'endpoint /api/vnnox-callback (consigliato in produzione).
VNNOX_CALLBACK_TOKEN=

# ── CRM su HubSpot (/crm · /api/crm/*) ──
# Private App access token di HubSpot (pat-...). Crealo in HubSpot:
#   Settings › Integrations › Private Apps › Create › scope crm.objects
#   contacts/companies/deals/quotes (read+write). Incollalo qui (locale .dev.vars)
#   e in Cloudflare Pages › Settings › Environment variables (produzione).
HUBSPOT_TOKEN=
