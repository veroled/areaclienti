---
/**
 * VeroCRM — CRM clienti VeroLED (areaclienti.veroledsrl.com).
 * App shell stile Light: sidebar (Dashboard · Pipeline · Contatti · Aziende ·
 * Preventivi · Schermi LED · Attività · Report · Impostazioni) + area di lavoro.
 * Pagina privata (noindex). I dati sono mock lato client: vanno sostituiti con
 * chiamate a /api/crm/* (Pages Functions + D1). La vista "Schermi LED" si
 * aggancia a /api/screens del portale Fleet Monitor PRO.
 */
export const prerender = true;
---
<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>VeroCRM · VeroLED</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,500&family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --accent: #1a8aab; --accent-2: #5aa829;
      --bg: #f4f6f8; --surface: #ffffff; --surface-2: #fafbfc;
      --text: #1c2430; --text-muted: #6b7682;
      --border: #e6eaee; --border-2: #eef1f4;
      --crit: #d83b40; --warn: #d98a16; --ok: #5aa829;
      --shadow: 0 1px 2px rgba(20,30,45,.04), 0 4px 14px rgba(20,30,45,.05);
    }
    * { box-sizing: border-box; }
    html, body { height: 100%; }
    body { margin: 0; background: var(--bg); color: var(--text); font-family: 'Open Sans', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
    .hidden { display: none !important; }
    h3,h4,h5 { margin: 0; }

    .app { display: grid; grid-template-columns: 240px 1fr; min-height: 100vh; }
    .side { background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; padding: 1.3rem 0; position: sticky; top: 0; height: 100vh; }
    .brand { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.55rem; line-height: 1.1; padding: 0 1.4rem 1.3rem; }
    .brand em { color: var(--accent); }
    .brand small { font-family: 'Open Sans'; font-style: normal; font-size: .6rem; letter-spacing: .14em; text-transform: uppercase; color: var(--accent); display: block; margin-top: 3px; }
    .nav { display: flex; flex-direction: column; gap: 1px; padding: .3rem .7rem; flex: 1; overflow-y: auto; }
    .nav .grp { font-size: .6rem; letter-spacing: .1em; text-transform: uppercase; color: var(--text-muted); padding: .9rem .8rem .35rem; }
    .nav a { display: flex; align-items: center; gap: .7rem; padding: .58rem .8rem; border-radius: 8px; color: var(--text-muted); text-decoration: none; font-size: .88rem; cursor: pointer; }
    .nav a:hover { background: var(--surface-2); color: var(--text); }
    .nav a.active { background: rgba(26,138,171,.1); color: var(--accent); font-weight: 600; }
    .nav a svg { width: 17px; height: 17px; flex: 0 0 17px; }
    .nav .count { margin-left: auto; font-size: .62rem; color: var(--text-muted); background: var(--border-2); padding: 1px 7px; border-radius: 10px; }
    .side-foot { padding: .9rem 1.2rem 0; border-top: 1px solid var(--border); margin-top: .4rem; display: flex; align-items: center; gap: .7rem; }
    .avatar { width: 34px; height: 34px; flex: 0 0 34px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: #fff; display: grid; place-items: center; font-weight: 700; font-size: .82rem; }
    .who { font-size: .82rem; line-height: 1.2; } .who small { display: block; color: var(--text-muted); font-size: .68rem; }

    .main { min-width: 0; }
    .topbar { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem 1.8rem; border-bottom: 1px solid var(--border); position: sticky; top: 0; background: rgba(244,246,248,.85); backdrop-filter: blur(8px); z-index: 5; }
    .topbar h2 { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 500; font-size: 1.7rem; margin: 0; }
    .search { flex: 1; max-width: 360px; position: relative; }
    .search input { width: 100%; padding: .55rem .8rem .55rem 2.1rem; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; color: var(--text); font-size: .85rem; font-family: inherit; }
    .search input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(26,138,171,.12); }
    .search svg { position: absolute; left: .7rem; top: 50%; transform: translateY(-50%); width: 15px; height: 15px; color: var(--text-muted); }
    .btn { padding: .55rem 1rem; background: var(--accent); color: #fff; border: 0; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: .82rem; font-family: inherit; display: inline-flex; align-items: center; gap: .4rem; white-space: nowrap; box-shadow: 0 2px 6px rgba(26,138,171,.25); }
    .btn:hover { filter: brightness(1.06); }
    .btn svg { width: 15px; height: 15px; }
    .ghost { background: var(--surface); border: 1px solid var(--border); color: var(--text-muted); padding: .5rem .8rem; border-radius: 8px; cursor: pointer; font-size: .8rem; font-family: inherit; display: inline-flex; align-items: center; gap: .4rem; }
    .ghost:hover { color: var(--text); border-color: var(--accent); }
    .ghost svg { width: 15px; height: 15px; }
    .content { padding: 1.6rem 1.8rem 4rem; }
    .burger { display: none; background: transparent; border: 0; color: var(--text); cursor: pointer; padding: .3rem; } .burger svg { width: 22px; height: 22px; }

    .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 1.4rem; }
    .kpi { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 1.1rem 1.2rem; box-shadow: var(--shadow); }
    .kpi .k-label { font-size: .72rem; letter-spacing: .04em; text-transform: uppercase; color: var(--text-muted); display: flex; align-items: center; gap: .5rem; }
    .kpi .k-label svg { width: 15px; height: 15px; color: var(--accent); }
    .kpi .k-val { font-size: 1.9rem; font-weight: 700; margin: .5rem 0 .15rem; line-height: 1; }
    .kpi .k-delta { font-size: .76rem; color: var(--text-muted); } .kpi .k-delta b { color: var(--ok); font-weight: 600; } .kpi .k-delta.down b { color: var(--crit); }

    .cols { display: grid; grid-template-columns: 1.6fr 1fr; gap: 1.2rem; }
    .panel { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 1.2rem 1.3rem; box-shadow: var(--shadow); }
    .panel-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
    .panel-head h3 { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 500; font-size: 1.3rem; }
    .panel-head a { font-size: .78rem; color: var(--accent); text-decoration: none; cursor: pointer; }

    .chart { display: flex; align-items: flex-end; gap: .55rem; height: 160px; padding-top: .5rem; }
    .chart .bar { flex: 1; display: flex; flex-direction: column; align-items: center; gap: .5rem; height: 100%; justify-content: flex-end; }
    .chart .bar i { width: 100%; max-width: 34px; background: linear-gradient(180deg, var(--accent), rgba(26,138,171,.35)); border-radius: 6px 6px 0 0; display: block; }
    .chart .bar:nth-child(odd) i { background: linear-gradient(180deg, var(--accent-2), rgba(90,168,41,.3)); }
    .chart .bar span { font-size: .68rem; color: var(--text-muted); }

    .feed { display: flex; flex-direction: column; }
    .feed .ev { display: flex; gap: .8rem; padding: .6rem 0; border-bottom: 1px solid var(--border-2); }
    .feed .ev:last-child { border-bottom: 0; }
    .ic { width: 30px; height: 30px; flex: 0 0 30px; border-radius: 8px; display: grid; place-items: center; background: rgba(26,138,171,.1); color: var(--accent); }
    .ic svg { width: 15px; height: 15px; } .ic.win { background: rgba(90,168,41,.12); color: var(--ok); } .ic.warn { background: rgba(217,138,22,.12); color: var(--warn); } .ic.crit { background: rgba(216,59,64,.12); color: var(--crit); }
    .feed .txt { font-size: .84rem; line-height: 1.35; align-self: center; } .feed .txt b { font-weight: 600; } .feed .txt small { display: block; color: var(--text-muted); font-size: .72rem; margin-top: 2px; }

    .board { display: grid; grid-auto-flow: column; grid-auto-columns: minmax(250px, 1fr); gap: 1rem; overflow-x: auto; padding-bottom: .8rem; }
    .col { background: var(--surface-2); border: 1px solid var(--border); border-radius: 12px; padding: .9rem; display: flex; flex-direction: column; min-height: 200px; }
    .col-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: .8rem; }
    .col-head h4 { font-size: .76rem; letter-spacing: .06em; text-transform: uppercase; color: var(--text-muted); display: flex; align-items: center; gap: .5rem; }
    .col-head .dot-s { width: 8px; height: 8px; border-radius: 50%; }
    .deal { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: .8rem .85rem; margin-bottom: .6rem; cursor: pointer; box-shadow: var(--shadow); }
    .deal:hover { border-color: var(--accent); } .deal h5 { font-size: .9rem; font-weight: 600; margin-bottom: .35rem; } .deal .co { font-size: .74rem; color: var(--text-muted); margin-bottom: .6rem; }
    .deal .row { display: flex; align-items: center; justify-content: space-between; } .deal .val { font-size: .9rem; font-weight: 700; color: var(--accent); }
    .tag { font-size: .64rem; text-transform: uppercase; letter-spacing: .04em; padding: 2px 7px; border-radius: 5px; background: var(--border-2); color: var(--text-muted); }
    .pill-avatar { width: 22px; height: 22px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: #fff; display: inline-grid; place-items: center; font-size: .62rem; font-weight: 700; }

    .toolbar { display: flex; align-items: center; gap: .6rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .chip { font-size: .78rem; padding: .4rem .8rem; border-radius: 20px; border: 1px solid var(--border); color: var(--text-muted); cursor: pointer; background: var(--surface); font-family: inherit; }
    .chip.on { background: rgba(26,138,171,.1); color: var(--accent); border-color: transparent; font-weight: 600; }
    .table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; box-shadow: var(--shadow); }
    table { width: 100%; border-collapse: collapse; }
    thead th { text-align: left; font-size: .68rem; letter-spacing: .06em; text-transform: uppercase; color: var(--text-muted); padding: .85rem 1.1rem; border-bottom: 1px solid var(--border); font-weight: 600; background: var(--surface-2); }
    tbody td { padding: .8rem 1.1rem; border-bottom: 1px solid var(--border-2); font-size: .86rem; }
    tbody tr:last-child td { border-bottom: 0; } tbody tr:hover { background: var(--surface-2); cursor: pointer; }
    .cell-name { display: flex; align-items: center; gap: .7rem; } .cell-name b { font-weight: 600; } .cell-name small { display: block; color: var(--text-muted); font-size: .72rem; }
    .badge { font-size: .68rem; padding: 3px 9px; border-radius: 20px; font-weight: 600; }
    .badge.lead { background: rgba(217,138,22,.14); color: var(--warn); } .badge.active { background: rgba(90,168,41,.14); color: var(--ok); } .badge.cold { background: var(--border-2); color: var(--text-muted); }
    .badge.online { background: rgba(90,168,41,.14); color: var(--ok); } .badge.offline { background: rgba(216,59,64,.14); color: var(--crit); }
    .badge.draft { background: var(--border-2); color: var(--text-muted); } .badge.sent { background: rgba(26,138,171,.14); color: var(--accent); } .badge.won { background: rgba(90,168,41,.14); color: var(--ok); }
    .stars { color: var(--warn); font-size: .8rem; letter-spacing: 1px; }
    .grid-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; }
    .ccard { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 1.1rem; box-shadow: var(--shadow); cursor: pointer; } .ccard:hover { border-color: var(--accent); }
    .ccard .top { display: flex; align-items: center; gap: .7rem; margin-bottom: .8rem; }
    .ccard .logo { width: 42px; height: 42px; border-radius: 10px; background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: #fff; display: grid; place-items: center; font-weight: 700; }
    .ccard h4 { font-size: .98rem; } .ccard .sub { font-size: .74rem; color: var(--text-muted); }
    .ccard .stat { display: flex; gap: 1.2rem; font-size: .78rem; color: var(--text-muted); margin-top: .6rem; padding-top: .7rem; border-top: 1px solid var(--border-2); } .ccard .stat b { display: block; color: var(--text); font-size: .95rem; }

    /* schermi LED */
    .screen { display: flex; align-items: center; gap: .9rem; }
    .screen .thumb { width: 52px; height: 34px; border-radius: 6px; background: linear-gradient(135deg,#10212a,#0a3343); border: 1px solid var(--border); position: relative; overflow: hidden; flex: 0 0 52px; }
    .screen .thumb::after { content:''; position: absolute; inset: 4px; border-radius: 3px; background: repeating-linear-gradient(45deg, rgba(26,138,171,.5) 0 3px, transparent 3px 6px); }
    .dot { display: inline-flex; align-items: center; gap: .4rem; font-size: .72rem; }
    .dot::before { content:''; width: 8px; height: 8px; border-radius: 50%; background: var(--text-muted); }
    .dot.online::before { background: var(--ok); box-shadow: 0 0 6px rgba(90,168,41,.6); } .dot.offline::before { background: var(--crit); }

    /* calendario */
    .cal { display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; }
    .cal .dow { text-align: center; font-size: .66rem; text-transform: uppercase; letter-spacing: .05em; color: var(--text-muted); padding: .3rem 0; }
    .cal .day { background: var(--surface-2); border: 1px solid var(--border-2); border-radius: 8px; min-height: 78px; padding: .4rem; font-size: .72rem; }
    .cal .day .n { color: var(--text-muted); font-weight: 600; } .cal .day.today { border-color: var(--accent); } .cal .day.today .n { color: var(--accent); }
    .cal .ap { margin-top: .25rem; font-size: .64rem; background: rgba(26,138,171,.12); color: var(--accent); border-radius: 4px; padding: 1px 5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cal .ap.g { background: rgba(90,168,41,.14); color: var(--ok); } .cal .ap.w { background: rgba(217,138,22,.14); color: var(--warn); }

    /* preventivo righe */
    .quote { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 1.4rem; box-shadow: var(--shadow); max-width: 720px; }
    .qline { display: grid; grid-template-columns: 1fr 70px 90px 90px; gap: .8rem; padding: .6rem 0; border-bottom: 1px solid var(--border-2); font-size: .85rem; align-items: center; }
    .qline.h { font-size: .66rem; text-transform: uppercase; letter-spacing: .05em; color: var(--text-muted); font-weight: 600; }
    .qline .r { text-align: right; } .qtot { display: flex; justify-content: flex-end; gap: 2rem; margin-top: 1rem; font-size: .95rem; } .qtot b { font-size: 1.2rem; color: var(--accent); }

    /* settings */
    .set-row { display: flex; align-items: center; justify-content: space-between; padding: .9rem 0; border-bottom: 1px solid var(--border-2); font-size: .88rem; }
    .set-row small { color: var(--text-muted); display: block; font-size: .76rem; margin-top: 2px; }
    .switch { width: 42px; height: 24px; border-radius: 20px; background: var(--border); position: relative; cursor: pointer; transition: background .2s; flex: 0 0 42px; }
    .switch::after { content:''; position: absolute; top: 3px; left: 3px; width: 18px; height: 18px; border-radius: 50%; background: #fff; box-shadow: var(--shadow); transition: left .2s; }
    .switch.on { background: var(--accent); } .switch.on::after { left: 21px; }

    /* drawer */
    .drawer-bg { position: fixed; inset: 0; background: rgba(20,30,45,.35); z-index: 20; opacity: 0; pointer-events: none; transition: opacity .25s; }
    .drawer-bg.open { opacity: 1; pointer-events: auto; }
    .drawer { position: fixed; top: 0; right: 0; height: 100%; width: 430px; max-width: 92vw; background: var(--surface); border-left: 1px solid var(--border); z-index: 21; transform: translateX(100%); transition: transform .28s ease; overflow-y: auto; box-shadow: -8px 0 30px rgba(20,30,45,.12); }
    .drawer.open { transform: translateX(0); }
    .d-head { padding: 1.4rem 1.4rem 1.2rem; border-bottom: 1px solid var(--border); position: relative; }
    .d-close { position: absolute; top: 1.1rem; right: 1.1rem; background: transparent; border: 0; color: var(--text-muted); cursor: pointer; font-size: 1.4rem; line-height: 1; }
    .d-avatar { width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: #fff; display: grid; place-items: center; font-weight: 700; font-size: 1.2rem; margin-bottom: .9rem; }
    .d-head h3 { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 500; font-size: 1.6rem; margin-bottom: .15rem; }
    .d-head .sub { font-size: .82rem; color: var(--text-muted); }
    .d-actions { display: flex; gap: .5rem; margin-top: 1rem; flex-wrap: wrap; }
    .d-body { padding: 1.3rem 1.4rem; }
    .d-section { margin-bottom: 1.5rem; } .d-section h4 { font-size: .7rem; letter-spacing: .06em; text-transform: uppercase; color: var(--text-muted); margin-bottom: .7rem; }
    .d-field { display: flex; align-items: center; gap: .7rem; padding: .5rem 0; font-size: .86rem; border-bottom: 1px solid var(--border-2); }
    .d-field svg { width: 16px; height: 16px; color: var(--accent); flex: 0 0 16px; } .d-field span { color: var(--text-muted); } .d-field b { margin-left: auto; font-weight: 600; }
    .note { background: var(--surface-2); border: 1px solid var(--border); border-left: 3px solid var(--accent); border-radius: 0 8px 8px 0; padding: .7rem .8rem; font-size: .82rem; line-height: 1.45; margin-bottom: .6rem; }
    .note small { display: block; color: var(--text-muted); font-size: .68rem; margin-top: .4rem; }
    .tabs { display: flex; gap: .3rem; border-bottom: 1px solid var(--border); margin-bottom: 1rem; }
    .tabs button { background: transparent; border: 0; padding: .55rem .7rem; font-size: .8rem; color: var(--text-muted); cursor: pointer; border-bottom: 2px solid transparent; font-family: inherit; }
    .tabs button.on { color: var(--accent); border-bottom-color: var(--accent); font-weight: 600; }

    @media (max-width: 1000px) { .cols { grid-template-columns: 1fr; } }
    @media (max-width: 760px) {
      .app { grid-template-columns: 1fr; }
      .side { position: fixed; top: 0; left: 0; z-index: 30; width: 256px; height: 100vh; transform: translateX(-100%); transition: transform .26s ease; box-shadow: var(--shadow); }
      .side.open { transform: translateX(0); box-shadow: 0 0 0 100vmax rgba(20,30,45,.35); }
      .burger { display: inline-flex; } .topbar h2 { font-size: 1.35rem; } .search { display: none; }
      .topbar, .content { padding-left: 1.1rem; padding-right: 1.1rem; }
      table { min-width: 600px; } .table-wrap { overflow-x: auto; } .cal .day { min-height: 56px; }
    }
  </style>
</head>
<body>
  <div class="app">
    <aside class="side" id="side">
      <div class="brand">Vero<em>CRM</em><small>VeroLED · Gestione clienti</small></div>
      <nav class="nav" id="nav">
        <div class="grp">Generale</div>
        <a data-sec="dashboard" class="active"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>Dashboard</a>
        <a data-sec="pipeline"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 6h18M3 12h18M3 18h18"/><circle cx="8" cy="6" r="1.4" fill="currentColor"/><circle cx="14" cy="12" r="1.4" fill="currentColor"/><circle cx="11" cy="18" r="1.4" fill="currentColor"/></svg>Pipeline <span class="count">12</span></a>
        <div class="grp">Anagrafiche</div>
        <a data-sec="contatti"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg>Contatti <span class="count">248</span></a>
        <a data-sec="aziende"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-3"/><path d="M9 9v.01M9 12v.01M9 15v.01"/></svg>Aziende <span class="count">96</span></a>
        <div class="grp">Vendite</div>
        <a data-sec="preventivi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M8 13h8M8 17h8"/></svg>Preventivi <span class="count">9</span></a>
        <a data-sec="schermi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>Schermi LED <span class="count">14</span></a>
        <div class="grp">Operativo</div>
        <a data-sec="attivita"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>Attività <span class="count">7</span></a>
        <a data-sec="report"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg>Report</a>
