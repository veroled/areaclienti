    document.getElementById('board').innerHTML = stages.map(s=>`
      <div class="col"><div class="col-head"><h4><span class="dot-s" style="background:${s.dot}"></span>${s.name}</h4><span style="font-size:.72rem;color:var(--text-muted)">${s.deals.length}</span></div>
      ${s.deals.map(d=>`<div class="deal" data-name="${d.co}" data-role="Trattativa" data-co="${d.t}"><h5>${d.t}</h5><div class="co">${d.co}</div><div class="row"><span class="val">${d.v}</span><span style="display:flex;align-items:center;gap:.4rem">${d.tag?`<span class="tag">${d.tag}</span>`:''}<span class="pill-avatar">${d.who}</span></span></div></div>`).join('')}</div>`).join('');

    // contatti
    const contacts = [
      {n:'Mario Rossi',r:'Direttore',co:'Sport Center Bari',st:'lead',stl:'Lead',v:'€ 18.500',p:3,d:'2 ore fa'},
      {n:'Lucia Bianchi',r:'Titolare',co:'Hotel Riviera',st:'lead',stl:'Lead',v:'€ 6.200',p:2,d:'Ieri'},
      {n:'Giuseppe Verdi',r:'Resp. acquisti',co:'Comune di Lecce',st:'active',stl:'Cliente',v:'€ 14.000',p:3,d:'Oggi'},
      {n:'Anna Esposito',r:'Marketing',co:'Centro Le Vele',st:'active',stl:'Cliente',v:'€ 9.800',p:2,d:'3 giorni fa'},
      {n:'Marco Greco',r:'Farmacista',co:'Farmacia San Marco',st:'lead',stl:'Lead',v:'€ 3.400',p:1,d:'Ieri'},
      {n:'Sara Conti',r:'Event manager',co:'Pro Loco Otranto',st:'active',stl:'Cliente',v:'€ 22.000',p:3,d:'5 giorni fa'},
      {n:'Davide Russo',r:'Titolare',co:'Studio Dentistico',st:'cold',stl:'Freddo',v:'€ 4.100',p:1,d:'2 sett. fa'},
    ];
    const stars = p => '★'.repeat(p) + '<span style="color:var(--border)">'+'★'.repeat(3-p)+'</span>';
    document.getElementById('tbody').innerHTML = contacts.map(c=>`
      <tr data-name="${c.n}" data-role="${c.r}" data-co="${c.co}">
        <td><div class="cell-name"><span class="pill-avatar" style="width:30px;height:30px;font-size:.7rem">${init(c.n)}</span><span><b>${c.n}</b><small>${c.r}</small></span></div></td>
        <td>${c.co}</td><td><span class="badge ${c.st}">${c.stl}</span></td>
        <td style="color:var(--accent);font-weight:600">${c.v}</td><td class="stars">${stars(c.p)}</td><td style="color:var(--text-muted)">${c.d}</td></tr>`).join('');

    // aziende
    const companies = [
      {n:'Sport Center Bari',t:'Cliente',c:'4 contatti',d:'2 trattative',v:'€ 18.500'},
      {n:'Comune di Lecce',t:'PA',c:'3 contatti',d:'1 schermo',v:'€ 14.000'},
      {n:'Hotel Riviera',t:'Prospect',c:'2 contatti',d:'2 schermi',v:'€ 6.200'},
      {n:'Centro Le Vele',t:'Cliente',c:'5 contatti',d:'3 schermi',v:'€ 9.800'},
      {n:'Pro Loco Otranto',t:'Cliente',c:'2 contatti',d:'1 trattativa',v:'€ 22.000'},
      {n:'Farmacia San Marco',t:'Prospect',c:'1 contatto',d:'lead',v:'€ 3.400'},
    ];
    document.getElementById('companies').innerHTML = companies.map(c=>`
      <div class="ccard" data-name="${c.n}" data-role="${c.t}" data-co="${c.c}">
        <div class="top"><div class="logo">${init(c.n)}</div><div><h4>${c.n}</h4><div class="sub">${c.t}</div></div></div>
        <div class="stat"><div><b>${c.c.split(' ')[0]}</b>contatti</div><div><b>${c.v}</b>valore</div></div>
      </div>`).join('');

    // preventivi
    const quotes = [
      {n:'2026-014',co:'Sport Center Bari',v:'€ 22.570',st:'sent',stl:'Inviato'},
      {n:'2026-013',co:'Centro Le Vele',v:'€ 11.956',st:'won',stl:'Accettato'},
      {n:'2026-012',co:'Hotel Riviera',v:'€ 7.564',st:'draft',stl:'Bozza'},
      {n:'2026-011',co:'Pro Loco Otranto',v:'€ 26.840',st:'sent',stl:'Inviato'},
    ];
    document.getElementById('quotes').innerHTML = quotes.map(q=>`
      <tr><td><div class="cell-name"><span><b>#${q.n}</b><small>${q.co}</small></span></div></td>
      <td style="font-weight:600">${q.v}</td><td><span class="badge ${q.st}">${q.stl}</span></td></tr>`).join('');

    // schermi LED (mock di /api/screens)
    const screens = [
      {n:'Insegna ingresso P3',co:'Sport Center Bari',m:'NovaStar TB60',on:true,b:80},
      {n:'Totem hall P2.5',co:'Hotel Riviera',m:'NovaStar TB40',on:false,b:0},
      {n:'LED piazza P4',co:'Comune di Lecce',m:'NovaStar TB60',on:true,b:65},
      {n:'Schermo vetrina P2.5',co:'Centro Le Vele',m:'NovaStar TB30',on:true,b:90},
      {n:'Maxischermo P5',co:'Pro Loco Otranto',m:'NovaStar TB60',on:true,b:70},
    ];
    document.getElementById('screens').innerHTML = screens.map(s=>`
      <tr><td><div class="screen"><div class="thumb"></div><b>${s.n}</b></div></td>
      <td>${s.co}</td><td style="color:var(--text-muted)">${s.m}</td>
      <td><span class="badge ${s.on?'online':'offline'}">${s.on?'online':'offline'}</span></td>
      <td>${s.on?s.b+'%':'—'}</td>
      <td><a class="ghost" style="text-decoration:none" href="/">apri nel portale →</a></td></tr>`).join('');

    // calendario giugno 2026 (1 giu = lunedì)
    const events = {3:[['Sopralluogo Lecce','g']],4:[['Richiamo Sport C.','w'],['Preventivo Riviera','']],11:[['Demo Le Vele','']],12:[['Firma Farmacia','g']],18:[['Installazione Otranto','']],25:[['Manutenzione','w']]};
    const dows = ['Lun','Mar','Mer','Gio','Ven','Sab','Dom'];
    let cal = dows.map(d=>`<div class="dow">${d}</div>`).join('');
    for(let d=1; d<=30; d++){
      const ev = (events[d]||[]).map(e=>`<div class="ap ${e[1]}">${e[0]}</div>`).join('');
      cal += `<div class="day${d===4?' today':''}"><div class="n">${d}</div>${ev}</div>`;
    }
    document.getElementById('cal').innerHTML = cal;

    // drawer
    const drawer = document.getElementById('drawer'), bg = document.getElementById('drawerBg');
    const openDrawer = (name, role, co) => {
      document.getElementById('dName').textContent = name; document.getElementById('dInit').textContent = init(name);
      document.getElementById('dSub').textContent = role + ' — ' + co;
      drawer.classList.add('open'); bg.classList.add('open');
    };
    const closeDrawer = () => { drawer.classList.remove('open'); bg.classList.remove('open'); };
    document.body.addEventListener('click', e => {
      const el = e.target.closest('[data-name]'); if(el && !e.target.closest('a')) openDrawer(el.dataset.name, el.dataset.role, el.dataset.co);
    });
    document.getElementById('dClose').onclick = closeDrawer; bg.onclick = closeDrawer;
    document.querySelectorAll('.tabs button').forEach(b => b.onclick = () => { document.querySelectorAll('.tabs button').forEach(x=>x.classList.remove('on')); b.classList.add('on'); });
    document.addEventListener('keydown', e => { if(e.key==='Escape') closeDrawer(); });
  </script>
</body>
</html>
