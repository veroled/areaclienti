---
// src/pages/admin/portale-clienti.astro
// Gestione accessi al PORTALE CLIENTI (areaclienti.veroledsrl.com · Fleet Monitor PRO).
// L'admin crea i clienti, imposta la password e associa gli ID schermo VNNOX.
// Login condiviso col resto dell'admin (sessionStorage vl_admin_secret → x-admin-secret).
// API: /api/admin/clienti (GET lista · POST upsert · DELETE ?piva=).
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin · Portale clienti — VeroLED</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;1,400;1,500&display=swap" rel="stylesheet" />
  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{--bg:#080a0d;--bg2:#0c0f13;--card:#0f1318;--card2:#12171d;--border:#222a33;--border2:#2c3540;--accent:#22a0c2;--gold:#c2a15e;--green:#3ecf8e;--red:#ef6360;--text:#f3f1ec;--muted:#8a8f99;--soft:#c7cbd2;--serif:'Cormorant Garamond',Georgia,serif;--sans:'Open Sans',-apple-system,system-ui,sans-serif;}
    body{background:radial-gradient(1100px 540px at 50% -8%,rgba(34,160,194,.06),transparent 60%),var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;line-height:1.55;-webkit-font-smoothing:antialiased;}
    a{color:inherit;text-decoration:none;}
    .nav{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-bottom:1px solid var(--border);background:rgba(12,15,19,.92);position:sticky;top:0;z-index:50;}
    .nav-l{display:flex;align-items:center;gap:14px;}
    .nav-l img{height:28px;width:auto;display:block;opacity:.95;}
    .divider{width:1px;height:24px;background:var(--border2);}
    .brand{font-size:13px;letter-spacing:.22em;color:var(--text);text-transform:uppercase;font-weight:600;}
    .brand small{display:block;font-size:8.5px;color:var(--gold);letter-spacing:.22em;margin-top:3px;font-weight:600;}
    .logout{background:transparent;border:1px solid var(--border2);border-radius:99px;padding:7px 14px;color:var(--muted);cursor:pointer;font-size:11px;}
    .wrap{max-width:820px;margin:0 auto;padding:26px 20px 90px;}
    .page-title{font-family:var(--serif);font-style:italic;font-weight:500;font-size:32px;color:#fbf9f4;margin:4px 0 6px;}
    .page-sub{font-size:13px;color:var(--muted);margin-bottom:18px;}
    .card{background:linear-gradient(180deg,var(--card2),var(--card));border:1px solid var(--border);border-radius:16px;padding:22px;margin-bottom:16px;}
    .card h2{display:flex;align-items:center;gap:10px;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--soft);margin-bottom:16px;font-weight:600;}
    .card h2::before{content:'';width:16px;height:1px;background:var(--gold);flex:none;}
    .field{margin-bottom:14px;}
    .field label{display:block;font-size:10px;letter-spacing:.13em;text-transform:uppercase;color:var(--muted);margin-bottom:7px;}
    .field .hint{font-size:11px;color:var(--muted);margin-top:6px;line-height:1.5;}
    .two{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
    input,textarea{width:100%;background:rgba(0,0,0,.28);border:1.5px solid var(--border2);border-radius:11px;padding:12px 14px;color:var(--text);font-size:14px;font-family:inherit;}
    textarea{min-height:64px;resize:vertical;}
    input::placeholder,textarea::placeholder{color:#6a6f78;}
    input:focus,textarea:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(34,160,194,.13);}
    .btn{background:var(--accent);color:#021018;border:none;border-radius:11px;padding:13px 20px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;}
    .btn.sm{padding:8px 13px;font-size:12px;border-radius:9px;}
    .btn.ghost{background:transparent;color:var(--text);border:1px solid var(--border2);}
    .btn.red{background:transparent;border:1px solid rgba(239,99,96,.5);color:var(--red);}
    .u{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;padding:14px 0;border-bottom:1px solid var(--border);}
    .u:last-child{border-bottom:none;}
    .u .n{font-weight:600;}.u .m{font-size:12px;color:var(--muted);margin-top:2px;}
    .ptags{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;}
    .ptag{font-size:10px;letter-spacing:.04em;padding:3px 8px;border-radius:99px;background:rgba(34,160,194,.13);color:var(--accent);}
    .err{color:var(--red);font-size:13px;margin-top:8px;}.ok{color:var(--green);font-size:13px;margin-top:8px;}
    .login{display:flex;align-items:center;justify-content:center;min-height:84vh;padding:24px;}
    .login .box{width:100%;max-width:380px;background:linear-gradient(180deg,var(--card2),var(--card));border:1px solid var(--border);border-radius:18px;padding:38px;}
    .login h1{font-family:var(--serif);font-style:italic;font-size:30px;margin-bottom:6px;color:#fbf9f4;}.login p{font-size:13px;color:var(--muted);margin-bottom:20px;}
    .note{font-size:12.5px;color:var(--muted);line-height:1.6;}
    .hidden{display:none!important;}
    .toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:var(--card2);border:1px solid var(--gold);border-radius:12px;padding:13px 22px;font-size:14px;z-index:200;opacity:0;transition:opacity .2s;}
    .toast.show{opacity:1;}
    @media(max-width:640px){.two{grid-template-columns:1fr;}.wrap{padding:22px 16px 80px;}}
  </style>
</head>
<body>
  <div class="nav">
    <a class="nav-l" href="/admin">
      <img src="/img/logo-veroled-white.svg" alt="VeroLED" />
      <div class="divider"></div>
      <div class="brand">Portale clienti<small>‹ tutti i pannelli</small></div>
    </a>
    <button class="logout hidden" id="logout">Esci</button>
  </div>

  <div class="login" id="login">
    <div class="box">
      <h1>Portale clienti</h1>
      <p>Accesso riservato.</p>
      <input type="password" id="pw" placeholder="Password admin" autocomplete="current-password" />
      <button class="btn" id="login-btn" style="width:100%;margin-top:14px;">Entra</button>
      <p class="err hidden" id="login-err"></p>
    </div>
  </div>

  <div class="wrap hidden" id="app">
    <div class="page-title">Portale clienti</div>
    <div class="page-sub">Crea gli accessi a <strong>areaclienti.veroledsrl.com</strong> e associa a ogni cliente i propri schermi VNNOX.</div>

    <div class="card" id="form-card">
      <h2 id="form-title">Nuovo cliente</h2>
      <div class="two">
        <div class="field"><label>Ragione sociale</label><input type="text" id="f-nome" placeholder="Es. Bar Centrale Srl" /></div>
        <div class="field"><label>P.IVA <span style="color:var(--muted)">(identificativo, non modificabile dopo)</span></label><input type="text" id="f-piva" placeholder="12345678901" /></div>
      </div>
      <div class="two">
        <div class="field"><label>Email</label><input type="text" id="f-email" placeholder="cliente@email.it" autocomplete="off" /></div>
        <div class="field"><label>Password (min 8 · vuota = invariata in modifica)</label><input type="text" id="f-pw" placeholder="password di accesso" autocomplete="off" /></div>
      </div>
      <div class="field">
        <label>Schermi VNNOX associati</label>
        <textarea id="f-screens" placeholder="Un ID per riga, oppure separati da virgola"></textarea>
        <div class="hint">ID dei player/schermi VNNOX visibili a questo cliente. In <strong>modalità demo</strong> usa: <code>TB60-0001</code>, <code>TB50-0042</code>, <code>MCTRL4K-0007</code>.</div>
      </div>
      <button class="btn" id="f-save">Salva cliente</button>
      <button class="btn ghost" id="f-reset" style="margin-left:8px;">Annulla</button>
      <div id="f-msg"></div>
    </div>

    <div class="card">
      <h2>Clienti del portale</h2>
      <div id="list"></div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script is:inline>
    (function () {
      var SECRET = '', EDIT = null;
      var $ = function (id) { return document.getElementById(id); };
      function esc(s){return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
      function toast(m){var t=$('toast');t.textContent=m;t.classList.add('show');setTimeout(function(){t.classList.remove('show');},2200);}
      function api(opts){return fetch(opts.url,{method:opts.method||'GET',headers:Object.assign({'x-admin-secret':SECRET},opts.body?{'Content-Type':'application/json'}:{}),body:opts.body?JSON.stringify(opts.body):undefined}).then(function(r){return r.json().then(function(j){return{status:r.status,j:j};});});}
      function parseScreens(txt){return String(txt||'').split(/[\n,;]+/).map(function(s){return s.trim();}).filter(Boolean);}

      function doLogin(){var pw=$('pw').value.trim();if(!pw)return;$('login-btn').disabled=true;SECRET=pw;
        api({url:'/api/admin/clienti'}).then(function(res){
          if(res.status===401){$('login-err').textContent='Password errata.';$('login-err').classList.remove('hidden');$('login-btn').disabled=false;SECRET='';return;}
          sessionStorage.setItem('vl_admin_secret',pw);enter(res.j);
        }).catch(function(){$('login-btn').disabled=false;$('login-err').textContent='Errore di rete.';$('login-err').classList.remove('hidden');});
      }
      function enter(payload){
        $('login').classList.add('hidden');$('app').classList.remove('hidden');$('logout').classList.remove('hidden');
        render((payload&&payload.clienti)||[]);
      }
      $('login-btn').addEventListener('click',doLogin);
      $('pw').addEventListener('keydown',function(e){if(e.key==='Enter')doLogin();});
      $('logout').addEventListener('click',function(){sessionStorage.removeItem('vl_admin_secret');location.reload();});

      function reload(){api({url:'/api/admin/clienti'}).then(function(res){if(res.j&&res.j.ok)render(res.j.clienti||[]);});}
      function render(clienti){
        if(!clienti.length){$('list').innerHTML='<p class="note">Nessun cliente ancora. Creane uno qui sopra.</p>';return;}
        $('list').innerHTML=clienti.map(function(c){
          var tags=(c.screens||[]).map(function(s){return '<span class="ptag">'+esc(s)+'</span>';}).join('')||'<span class="ptag" style="background:rgba(239,99,96,.14);color:var(--red);">nessuno schermo</span>';
          return '<div class="u"><div style="flex:1;"><div class="n">'+esc(c.nome||c.piva)+'</div>'+
            '<div class="m">P.IVA '+esc(c.piva)+(c.email?' · '+esc(c.email):'')+(c.lastLogin?' · ultimo accesso '+new Date(c.lastLogin).toLocaleDateString("it-IT"):' · mai entrato')+'</div>'+
            '<div class="ptags">'+tags+'</div></div>'+
            '<div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;"><button class="btn sm ghost" data-edit="'+esc(c.piva)+'">Modifica</button><button class="btn sm red" data-del="'+esc(c.piva)+'">Rimuovi</button></div></div>';
        }).join('');
        Array.prototype.forEach.call($('list').querySelectorAll('[data-del]'),function(b){b.addEventListener('click',function(){
          var piva=b.getAttribute('data-del'); if(!confirm('Revocare l\'accesso al cliente con P.IVA '+piva+'?'))return;
          api({url:'/api/admin/clienti?piva='+encodeURIComponent(piva),method:'DELETE'}).then(function(){toast('Cliente rimosso');reload();});
        });});
        Array.prototype.forEach.call($('list').querySelectorAll('[data-edit]'),function(b){b.addEventListener('click',function(){
          var piva=b.getAttribute('data-edit'); var c=(clienti.filter(function(x){return x.piva===piva;})[0]||{});
          EDIT=piva; $('form-title').textContent='Modifica '+(c.nome||piva);
          $('f-nome').value=c.nome||''; $('f-piva').value=c.piva||''; $('f-piva').disabled=true;
          $('f-email').value=c.email||''; $('f-pw').value=''; $('f-screens').value=(c.screens||[]).join('\n');
          window.scrollTo({top:0,behavior:'smooth'});
        });});
      }
      function resetForm(){EDIT=null;$('form-title').textContent='Nuovo cliente';['f-nome','f-piva','f-email','f-pw','f-screens'].forEach(function(id){$(id).value='';});$('f-piva').disabled=false;$('f-msg').textContent='';$('f-msg').className='';}
      $('f-reset').addEventListener('click',resetForm);

      $('f-save').addEventListener('click',function(){
        var nome=$('f-nome').value.trim(),piva=$('f-piva').value.trim(),email=$('f-email').value.trim(),pw=$('f-pw').value,screens=parseScreens($('f-screens').value);
        var m=$('f-msg');m.className='';m.textContent='';
        if(!piva){m.className='err';m.textContent='La P.IVA è obbligatoria.';return;}
        if(!EDIT&&(!pw||pw.length<8)){m.className='err';m.textContent='Imposta una password di almeno 8 caratteri.';return;}
        var body={piva:piva,nome:nome,email:email,screens:screens};if(pw)body.password=pw;
        $('f-save').disabled=true;
        api({url:'/api/admin/clienti',method:'POST',body:body}).then(function(res){
          $('f-save').disabled=false;
          if(res.j&&res.j.ok){m.className='ok';m.textContent='✓ Cliente salvato.';resetForm();reload();}
          else{m.className='err';m.textContent='Errore: '+({piva_mancante:'P.IVA mancante',password_corta:'password troppo corta (min 8)',password_richiesta:'serve una password per il nuovo cliente'}[res.j&&res.j.error]||(res.j&&res.j.error)||'riprova');}
        }).catch(function(){$('f-save').disabled=false;m.className='err';m.textContent='Errore di rete.';});
      });

      var saved=sessionStorage.getItem('vl_admin_secret');
      if(saved){SECRET=saved;api({url:'/api/admin/clienti'}).then(function(res){if(res.status===200&&res.j&&res.j.ok)enter(res.j);else SECRET='';}).catch(function(){});}
    })();
  </script>
</body>
</html>
